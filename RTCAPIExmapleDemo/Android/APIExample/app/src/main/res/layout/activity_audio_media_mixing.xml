<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".examples.AudioMixing.AudioMediaMixingActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/local_view_container"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            />

        <LinearLayout
            android:id="@+id/main_room_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >

            <EditText
                android:id="@+id/room_id_input"
                android:layout_width="match_parent"
                android:layout_weight="1"
                android:layout_height="36dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                android:hint="@string/hint_room_id"
                android:paddingLeft="5dp"
                android:layout_marginTop="10dp"
                />
            <Button
                android:id="@+id/btn_join_room"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/button_join_room"
                android:layout_gravity="right"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="5dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/layout_background">

            <TextView
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="@string/title_audio_mixing" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_mixing_file_label"/>

                <EditText
                    android:id="@+id/res_input1"
                    android:layout_width="0dp"
                    android:textSize="12sp"
                    android:text="qilixiang.m4a"
                    android:paddingLeft="10dp"
                    android:layout_height="36dp"
                    android:layout_weight="4"
                    android:enabled="false"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">


                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_open"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:textSize="12sp"
                    android:paddingHorizontal="0dp"
                    android:text="@string/button_open"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_play"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/button_play"
                    android:textSize="12sp"
                    android:layout_weight="1"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_pause"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/button_pause"
                    android:textSize="12sp"
                    android:layout_weight="1"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_resume"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/button_resume"
                    android:textSize="12sp"
                    android:layout_weight="1"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_stop"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/button_stop"
                    android:textSize="12sp"
                    android:layout_weight="1"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_play_progress"/>

                <SeekBar
                    android:id="@+id/progress_bar1"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="5dp"
                    android:progress="0"
                    android:thumb="@null"
                    android:splitTrack="false"/>
                <TextView
                    android:id="@+id/progress_text1"
                    android:layout_marginEnd="16dp"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp">
                <EditText
                    android:id="@+id/progress_input"
                    android:layout_width="match_parent"
                    android:textSize="12sp"
                    android:layout_height="36dp"
                    android:layout_weight="4"
                    android:hint="@string/hint_progress_ms"
                    android:paddingLeft="5dp"
                    android:inputType="number"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_set_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:textSize="12sp"
                    android:paddingHorizontal="0dp"
                    android:text="@string/label_set_progress"/>

                <EditText
                    android:id="@+id/audio_track_input"
                    android:layout_width="match_parent"
                    android:textSize="12sp"
                    android:layout_height="36dp"
                    android:paddingLeft="5dp"
                    android:layout_weight="4"
                    android:hint="@string/hint_audio_track"
                    android:inputType="number"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_set_audio_track"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:textSize="12sp"
                    android:paddingHorizontal="0dp"
                    android:text="@string/label_set_audio_track"/>

            </LinearLayout>

        </LinearLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="5dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/layout_background"
            >

            <TextView
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="@string/label_pcm_mixing" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_play2"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/button_play"
                    android:textSize="12sp"
                    android:layout_weight="1"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_pause2"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/button_pause"
                    android:textSize="12sp"
                    android:layout_weight="1"
                    android:visibility="gone"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_resume2"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/button_pause"
                    android:textSize="12sp"
                    android:layout_weight="1"
                    android:visibility="gone"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_stop2"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="@string/button_stop"
                    android:textSize="12sp"
                    android:layout_weight="1"/>
            </LinearLayout>

        </LinearLayout>



        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="10dp"
            android:background="@color/grey"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:text="@string/label_volume"/>

            <SeekBar
                android:id="@+id/volume_bar1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:max="400"
                android:progress="100"/>
            <TextView
                android:id="@+id/volume_text1"
                android:layout_marginEnd="16dp"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="100"
                android:gravity="center"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>