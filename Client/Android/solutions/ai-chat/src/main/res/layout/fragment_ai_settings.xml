<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#f6f8fa"
        android:scaleType="fitStart"
        android:src="@drawable/bg_ai_settings"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="0dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="0dp"
        tools:layout_constraintGuide_begin="44dp" />

    <ImageView
        android:id="@+id/back"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="6dp"
        android:contentDescription="@string/back"
        android:scaleType="center"
        android:src="@drawable/ic_arrow_left24_b"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_top" />

    <TextView
        android:id="@+id/save"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginEnd="6dp"
        android:gravity="center"
        android:paddingHorizontal="10dp"
        android:text="@string/ai_save"
        android:textColor="#1664FF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_top"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:text="@string/ai_settings"
        android:textColor="#1D2129"
        android:textFontWeight="700"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/label_integration_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="@string/ai_setting_label_integration_mode"
                android:textColor="#737A87" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="112dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_ai_card_r8">

                <TextView
                    android:id="@+id/mode_realtime"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_gravity="top"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="@string/ai_setting_label_integration_mode_realtime"
                    android:textColor="#020814"
                    android:textSize="16sp"
                    app:drawableEndCompat="@drawable/ic_ai_option"
                    tools:drawableEnd="@drawable/ic_ai_option_selected" />

                <TextView
                    android:id="@+id/mode_flexible"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_gravity="bottom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:text="@string/ai_setting_label_integration_mode_flexible"
                    android:textColor="#020814"
                    android:textSize="16sp"
                    app:drawableEndCompat="@drawable/ic_ai_option"
                    tools:drawableEnd="@drawable/ic_ai_option_selected" />
            </FrameLayout>

            <TextView
                android:id="@+id/label_character_settings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="@string/ai_setting_label_character_settings"
                android:textColor="#737A87" />

            <include
                android:id="@+id/welcome_speech"
                layout="@layout/item_ai_character_setting_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/label_character_settings" />

            <include
                android:id="@+id/prompt"
                layout="@layout/item_ai_character_setting_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/welcome_speech" />

            <TextView
                android:id="@+id/label_core_functions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="@string/ai_setting_label_core_functions"
                android:textColor="#737A87"
                app:layout_constraintTop_toBottomOf="@id/prompt" />

            <include
                android:id="@+id/voice_type_realtime"
                layout="@layout/item_ai_core_setting_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/label_core_functions" />

            <include
                android:id="@+id/voice_type_flexible"
                layout="@layout/item_ai_core_setting_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/label_core_functions" />

            <include
                android:id="@+id/llm_model"
                layout="@layout/item_ai_core_setting_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/voice_type_flexible" />

            <include
                android:id="@+id/asr_model"
                layout="@layout/item_ai_core_setting_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/llm_model" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>