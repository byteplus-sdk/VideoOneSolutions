<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ai_conversation">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="0dp"
        tools:layout_constraintGuide_begin="44dp" />

    <ImageView
        android:id="@+id/back"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="6dp"
        android:contentDescription="@string/back"
        android:scaleType="center"
        android:src="@drawable/ic_arrow_left24_b"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_top" />

    <ImageView
        android:id="@+id/settings"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="6dp"
        android:contentDescription="@string/settings"
        android:scaleType="center"
        android:src="@drawable/ic_ai_settings"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_top" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_top">

        <TextView
            android:id="@+id/time_remaining"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:drawablePadding="6dp"
            android:gravity="center_vertical"
            android:textColor="#42464E"
            android:textSize="14sp"
            android:visibility="gone"
            app:drawableStartCompat="@drawable/ic_ai_time_remaining"
            tools:drawableStart="@drawable/ic_ai_time_remaining"
            tools:text="Time remaining: 10:00"
            tools:visibility="visible" />
    </LinearLayout>


    <ImageView
        android:id="@+id/ai_avatar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/avatar_top_normal"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_ai_avatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_top" />

    <TextView
        android:id="@+id/ai_tips"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="21dp"
        android:gravity="center_horizontal"
        android:textColor="#42464E"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ai_avatar"
        tools:text="@string/ai_tips_preparing" />

    <TextView
        android:id="@+id/ai_ready_tips"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="21dp"
        android:layout_marginTop="46dp"
        android:gravity="center_horizontal"
        android:text="@string/ai_tips_ready"
        android:textColor="#42464E"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ai_avatar" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ai_ready_questions"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="21dp"
        android:layout_marginVertical="18dp"
        app:layout_constraintBottom_toTopOf="@id/mic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ai_ready_tips"
        tools:background="#11FF00FF" />

    <androidx.constraintlayout.widget.Group
        android:id="@+id/group_ai_ready"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:constraint_referenced_ids="ai_ready_tips, ai_ready_questions"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/mic"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="42dp"
        android:layout_marginBottom="46dp"
        android:background="@drawable/bg_ai_circle_white"
        android:scaleType="center"
        android:src="@drawable/ic_ai_mic"
        app:layout_constraintBottom_toBottomOf="@id/guideline_bottom"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/hangup"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginEnd="42dp"
        android:layout_marginBottom="46dp"
        android:background="@drawable/bg_ai_circle_red"
        android:scaleType="center"
        android:src="@drawable/ic_ai_hangup"
        app:layout_constraintBottom_toBottomOf="@id/guideline_bottom"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_bottom"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintGuide_end="0dp"
        tools:layout_constraintGuide_end="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>