<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/bg_ai_card_r8"
    android:orientation="horizontal"
    android:padding="8dp"
    tools:showIn="@layout/fragment_ai_setting_recycler">

    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp">

        <ImageView
            android:id="@+id/icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            tools:src="@tools:sample/avatars" />

        <ImageView
            android:id="@+id/icon_pause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_ai_voice_type_icon_r6"
            android:scaleType="center"
            android:src="@drawable/ic_ai_voicetype_pause"
            android:visibility="gone"
            tools:visibility="visible"/>
    </FrameLayout>

    <TextView
        android:id="@+id/text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="22dp"
        android:layout_weight="1"
        android:textColor="#020814"
        android:textSize="16sp"
        tools:text="@tools:sample/cities" />

    <LinearLayout
        android:id="@+id/chosen"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/bg_ai_button_chosen"
        android:paddingHorizontal="12dp">

        <ImageView
            android:id="@+id/chosen_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_ai_setting_chosen"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/chosen_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="@string/ai_setting_chosen"
            android:textColor="@color/color_ai_button_chosen"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>