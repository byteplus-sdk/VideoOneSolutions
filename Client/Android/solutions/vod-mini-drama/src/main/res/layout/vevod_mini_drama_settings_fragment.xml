<com.byteplus.vod.minidrama.scene.widgets.viewpager2.ViewPager2ChildFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.byteplus.vod.minidrama.scene.settings.DramaSettingsFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/vevod_mini_drama_tab_settings">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:textColor="#E6FFFFFF"
                android:text="@string/vevod_mini_drama_tab_settings_ads" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1D2129">

                <androidx.appcompat.widget.SwitchCompat xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:id="@+id/prerollSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:minHeight="48dp"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:text="@string/vevod_mini_drama_preroll_ads"
                    android:theme="@style/Theme.AppCompat.DayNight"
                    tools:theme="@style/Theme.AppCompat.DayNight" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1D2129">

                <androidx.appcompat.widget.SwitchCompat xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:id="@+id/midrollSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:minHeight="48dp"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:checked="true"
                    android:text="@string/vevod_mini_drama_midroll_ads"
                    android:theme="@style/Theme.AppCompat.DayNight"
                    tools:theme="@style/Theme.AppCompat.DayNight" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1D2129">

                <androidx.appcompat.widget.SwitchCompat xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:id="@+id/postrollSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:minHeight="48dp"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:text="@string/vevod_mini_drama_postroll_ads"
                    android:theme="@style/Theme.AppCompat.DayNight"
                    tools:theme="@style/Theme.AppCompat.DayNight" />
            </FrameLayout>
        </LinearLayout>
    </ScrollView>
</com.byteplus.vod.minidrama.scene.widgets.viewpager2.ViewPager2ChildFrameLayout>